# Copy this file to `.env` and fill the values.
# Required for public webhook callbacks (ngrok/cloudflared URL)
PUBLIC_BASE_URL=https://inspirable-still-aleida.ngrok-free.dev

# Recommended for Twilio webhook signature validation
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# Optional Twilio transcription tuning
TWILIO_TRANSCRIPTION_TRACK=both_tracks
TWILIO_TRANSCRIPTION_LANGUAGE=en-US
TWILIO_TRANSCRIPTION_ENGINE=google
TWILIO_TRANSCRIPTION_MODEL=telephony

# Required for Vercel deployment (state persistence)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key   # backend only, never expose
SUPABASE_ANON_KEY=your_anon_key                   # safe to send to browser

# Optional: Gemini API key for AI-generated call summaries and issue titles
GEMINI_API_KEY=your_gemini_api_key

# Optional: Google Maps API key for outage location geocoding
GOOGLE_MAPS_API_KEY=your_key_here

# Optional app port
PORT=8080
